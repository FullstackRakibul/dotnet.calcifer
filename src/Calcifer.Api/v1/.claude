      ]
    },
    "phase4_planned": {
      "name": "Security Hardening",
      "status": "Partial",
      "work": [
        "Add rate limiting (AspNetCoreRateLimit)",
        "HSTS for production",
        "Fix CORS wildcard for production",
        "Move JWT secret to user-secrets/Key Vault",
        "Verify all DateTime.Now → DateTime.UtcNow"
      ]
    },
    "phase5_planned": {
      "name": "IP/Device Tracking",
      "status": "❌ Not implemented",
      "work": ["Create IpDeviceTrackingMiddleware", "Track IP + UserAgent on all auth operations"]
    },
    "phase6_planned": {
      "name": "Testing Suite",
      "status": "❌ Not implemented",
      "work": ["Unit tests for AuthService, TokenService", "Integration tests with WebApplicationFactory"]
    },
    "phase7_planned": {
      "name": "Controller Consolidation",
      "status": "❌ Not done",
      "work": [
        "Delete AuthController.cs and RoleController.cs",
        "Keep only HomeController.cs as example (or rename to WelcomeController)"
      ]
    }
  },

  "knownIssues": [
    {
      "issue": "Duplicate ILicenseService",
      "severity": "MEDIUM",
      "locations": ["Interface/Licensing/ILicenseService.cs (725 bytes)", "DbContexts/Licensing/ILicenseService.cs (4,309 bytes)"],
      "fix": "Keep DbContexts version (full contract), delete Interface/ version or make Interface/ version the canonical one"
    },
    {
      "issue": "AuthController + RoleController still exist",
      "severity": "MEDIUM",
      "locations": ["AuthHandler/AuthController/AuthController.cs", "AuthHandler/AuthController/RoleController.cs"],
      "fix": "Delete both — all auth logic already in IdentityApi.cs"
    },
    {
      "issue": "LogWriter not registered in DI container",
      "severity": "HIGH",
      "location": "DependencyContainer/DependencyInversion.cs",
      "fix": "Add services.AddDynamicLogWriter() call"
    },
    {
      "issue": "JWT secret in appsettings.Development.json",
      "severity": "CRITICAL",
      "fix": "Move to dotnet user-secrets"
    }
  ]
}