{
  "projectMetadata": {
    "name": "Calcifer.Api",
    "description": "Enterprise-grade ASP.NET Core 8.0 API with advanced RBAC, licensing, feature-gating, dynamic logging, and module-based architecture",
    "framework": ".NET 8.0",
    "language": "C#",
    "maintainedBy": "Rakibul H. Rabbi",
    "version": "1.1.0",
    "createdDate": "2026-04-27",
    "lastAuditDate": "2026-04-29",
    "status": "Production-Ready with Hardening Roadmap"
  },

  "architecture": {
    "type": "Layered Monolith with Enterprise Patterns (Microservice-Ready)",
    "pattern": "5-Layer Vertical Slice + Cross-Cutting Infrastructure",
    "layers": [
      {
        "name": "API Layer",
        "description": "HTTP entry points using Pure Minimal APIs (primary) with legacy Controllers",
        "paths": [
          "AuthHandler/MinimalApis/IdentityApi.cs",
          "AuthHandler/MinimalApis/LicenseApi.cs",
          "Rbac/MinimalApis/RbacMinimalApi.cs",
          "MinimalApis/PublicApis/PublicCRUDApis.cs",
          "MinimalApis/PublicApis/CommonStatusApi.cs",
          "Controllers/HomeController.cs (legacy example)"
        ],
        "responsibility": "Route mapping, DTO marshaling, HTTP status codes, filter application"
      },
      {
        "name": "DTO Layer",
        "description": "Request/Response contracts ensuring zero domain model leakage",
        "path": "DbContexts/DTOs/",
        "responsibility": "Data shape contracts, validation attributes, serialization",
        "keyFiles": [
          "AuthDTO/LoginRequestDto.cs",
          "AuthDTO/RegisterRequestDto.cs",
          "AuthDTO/AuthDTOs.cs",
          "AuthDTO/AssignRoleRequestDto.cs",
          "AuthDTO/CreateRoleRequestDto.cs",
          "CommonDTO/CommonStatusDto.cs",
          "LicenseDTO/LicenseDto.cs",
          "ModelsDTO/PublicDto.cs",
          "ClientTypeDto.cs",
          "PublicDataDTO.cs"
        ]
      },
      {
        "name": "Service Layer",
        "description": "Business logic, RBAC resolution, licensing checks, auth workflows, logging",
        "paths": [
          "Services/AuthService/AuthService.cs",
          "Services/AuthService/TokenService.cs",
          "Services/AuthService/RoleService.cs",
          "Services/LicenseService/LicenseService.cs",
          "Services/PublicService.cs",
          "Rbac/Services/Rbacservice.cs"
        ],
        "responsibility": "Orchestration, business rules, transaction management, ILogWriter integration"
      },
      {
        "name": "Interface Layer",
        "description": "Service contracts enabling loose coupling and dependency injection",
        "paths": [
          "Interface/Common/IPublicInterface.cs",
          "Interface/Licensing/ILicenseService.cs",
          "Rbac/Interfaces/IRbacService.cs"
        ],
        "responsibility": "Abstract service contracts",
        "knownIssue": "Duplicate ILicenseService exists at DbContexts/Licensing/ILicenseService.cs — consolidate to Interface/"
      },
      {
        "name": "Data Access Layer",
        "description": "EF Core DbContext, entities, migrations, AuditBase tracking",
        "path": "DbContexts/",
        "responsibility": "Database communication, change tracking, soft-delete enforcement",
        "keyFiles": [
          "CalciferAppDbContext.cs",
          "AuthModels/ApplicationUser.cs",
          "AuthModels/ApplicationRole.cs",
          "Common/Auditbase.cs",
          "Common/CommonStatus.cs",
          "Common/TableOperationDetails.cs",
          "Licensing/License.cs",
          "Licensing/LicenseType.cs",
          "Licensing/LicenseFeature.cs",
          "Licensing/LicenseActivation.cs",
          "Models/PublicData.cs",
          "Enum/CommonStatusEnum.cs"
        ]
      }
    ],
    "crossCuttingConcerns": {
      "authentication": {
        "type": "JWT Bearer (HMAC-SHA256)",
        "location": "AuthHandler/Configuration/JwtSettings.cs",
        "tokenExpiry": "60 minutes (configurable via appsettings.json)"
      },
      "authorization": {
        "filterChain": "License → RBAC → Auth → Request Handler",
        "filters": [
          {
            "order": 1,
            "filter": "LicenseValidationFilter",
            "type": "IAsyncAuthorizationFilter",
            "purpose": "[RequireFeature] - Module-level gate",
            "location": "AuthHandler/Filters/LicenseValidationFilter.cs"
          },
          {
            "order": 2,
            "filter": "RbacAuthorizationFilter",
            "type": "IAsyncAuthorizationFilter",
            "purpose": "[RequirePermission] - Permission-level gate (Module:Resource:Action)",
            "location": "AuthHandler/Filters/RbacFilter.cs"
          },
          {
            "order": 3,
            "filter": "AuthorizationFilter",
            "type": "IEndpointFilter (Minimal APIs)",
            "purpose": "Global JWT check for /api/v1 group",
            "location": "AuthHandler/Filters/AuthorizationFilter.cs"
          }
        ]
      },
      "claims": {
        "location": "AuthHandler/Claims/CustomClaims.cs",
        "constants": ["name", "region", "role", "perms", "unit_roles", "emp_id"]
      },
      "logging": {
        "implementation": "Helper/LogWriter/LogWriter.cs",
        "interface": "ILogWriter (singleton)",
        "location": "Logs to /logs directory (text-based, UTF-8)",
        "fileNaming": "YYYY-MM-DD_LogType.txt",
        "logTypes": ["Action", "Validation", "Error", "Response", "Try", "Failed"],
        "features": [
          "Correlation IDs for distributed tracing",
          "IP address + User ID tracking",
          "Exception stack traces",
          "Full audit trail"
        ],
        "registration": "services.AddDynamicLogWriter() — NOT YET ADDED to DependencyInversion.cs"
      }
    },
    "microserviceReadiness": {
      "status": "60% Ready",
      "readyForSeparation": [
        { "module": "RBAC", "reason": "Clear interface (IRbacService), isolated entities at Rbac/", "blockers": "Shared database" },
        { "module": "Licensing", "reason": "Independent feature gates, clean interface", "blockers": "Shared database, no async events" },
        { "module": "Authentication", "reason": "Standard JWT/OAuth pattern", "blockers": "Shared user database, tightly coupled to Identity" }
      ],
      "missingForFullMicroservices": [
        "Async event bus (RabbitMQ/Azure Service Bus)",
        "Service discovery (Consul/Kubernetes-native)",
        "API Gateway",
        "Database per service (currently shared CalciferAppDbContext)"
      ]
    }
  },

  "tokenManagement": {
    "jwt": {
      "scheme": "Bearer (HMAC-SHA256 symmetric key)",
      "expiry": "60 minutes (configurable)",
      "optimizedClaims": {
        "sub": "User ID",
        "email": "User email",
        "name": "Display name",
        "emp_id": "Employee ID",
        "roles": "ASP.NET roles",
        "perms": "Embedded RBAC permissions (Module:Resource:Action format)",
        "unit_id": "Current org context (single value, not array)"
      },
      "note": "unit_roles array should be moved to PermissionCache to keep JWT size small"
    },
    "refreshTokens": {
      "implemented": false,
      "planned": {
        "table": "RefreshTokens",
        "expiry": "30 days",
        "properties": ["Token (hashed)", "IssuedAt (UTC)", "ExpiresAt (UTC)", "RevokedAt (nullable)", "IpAddress", "DeviceFingerprint"],
        "endpoint": "POST /api/v1/auth/refresh"
      }
    },
    "tokenRevocation": {
      "implemented": false,
      "planned": {
        "table": "TokenRevocations",
        "purpose": "Logout should invalidate tokens immediately",
        "tracks": ["JWT ID (jti)", "User ID", "Revoked reason", "IP address", "Expiration"],
        "check": "RbacFilter validates token not in revocation list",
        "endpoint": "POST /api/v1/auth/logout"
      }
    }
  },

  "auditTrail": {
    "currentState": {
      "baseClass": "AuditBase (DbContexts/Common/Auditbase.cs)",
      "fields": ["CreatedAt (DateTime.UtcNow)", "CreatedBy", "UpdatedAt", "UpdatedBy", "DeletedAt", "DeletedBy", "IsDeleted"],
      "missingFields": ["CorrelationId", "IpAddress", "UserAgent"]
    },
    "planned": {
      "fieldLevelTracking": true,
      "newTable": "AuditLogs",
      "tracks": [
        "Entity name and ID",
        "Action (Created, Updated, Deleted)",
        "Field name, old value, new value",
        "Who changed it (UserId)",
        "When it changed (timestamp in UTC)",
        "IP address of changer",
        "Device/browser user agent"
      ]
    }
  },

  "moduleSystem": {
    "implemented": false,
    "planned": {
      "interface": "IModule with RegisterServices(), RegisterEndpoints(), RegisterFilters()",
      "coreModules": [
        { "name": "Auth", "isCore": true, "description": "Authentication, user management, token generation", "alwaysLoaded": true }
      ],
      "optionalModules": [
        { "name": "RBAC", "enabledBy": "License feature 'RBAC'" },
        { "name": "HCM", "enabledBy": "License feature 'HCM'" },
        { "name": "Finance", "enabledBy": "License feature 'Finance'" }
      ],
      "benefit": "Clean separation, modular codebase, easier microservice extraction"
    }
  },

  "modules": {
    "authentication": {
      "description": "User registration, login, profile management, password changes",
      "paths": ["AuthHandler/MinimalApis/IdentityApi.cs", "Services/AuthService/"],
      "endpoints": [
        "POST /api/v1/auth/register (public)",
        "POST /api/v1/auth/login (public)",
        "GET /api/v1/auth/me (requires auth)",
        "POST /api/v1/auth/change-password (requires auth)"
      ],
      "services": ["AuthService", "TokenService", "RoleService"],
      "dbEntities": ["ApplicationUser", "ApplicationRole"]
    },
    "rbac": {
      "description": "Enterprise permission management with org unit context and caching",
      "paths": ["Rbac/", "AuthHandler/Filters/RbacFilter.cs"],
      "endpoints": [
        "GET /api/v1/rbac/roles",
        "POST /api/v1/rbac/roles/assign",
        "POST /api/v1/rbac/permissions/direct",
        "12 total RBAC management endpoints"
      ],
      "services": ["RbacService (Rbac/Services/Rbacservice.cs)"],
      "keyFeatures": [
        "Module:Resource:Action permission model",
        "Organization unit tree (Company→Factory→Dept→Team)",
        "User role assignment with temporal scoping (ValidFrom, ValidTo)",
        "Direct permission grants/denies",
        "Permission caching with 5-minute TTL",
        "JWT claim embedding to reduce DB load"
      ],
      "dbEntities": ["OrganizationUnit", "Permission", "RolePermission", "UserUnitRole", "UserDirectPermission", "PermissionCache"],
      "supportFiles": ["Rbac/DTOs/RbacDTOs.cs", "Rbac/Enums/Rbacenums.cs", "Rbac/Extensions/RbacExtensions.cs", "Rbac/Seeds/OrgUnitSeeder.cs", "Rbac/Seeds/Rbacpermissionseeder.cs"]
    },
    "licensing": {
      "description": "License validation, feature enablement, machine activation tracking",
      "paths": ["Services/LicenseService/", "AuthHandler/Filters/LicenseValidationFilter.cs"],
      "endpoints": [
        "GET /api/v1/licenses",
        "POST /api/v1/licenses/activate",
        "POST /api/v1/licenses/validate"
      ],
      "services": ["LicenseService"],
      "dbEntities": ["License", "LicenseType", "LicenseFeature", "LicenseActivation"]
    },
    "publicApi": {
      "description": "Public-facing endpoints for non-authenticated operations",
      "paths": ["MinimalApis/PublicApis/"],
      "endpoints": ["GET /api/v1/public", "GET /public/status"],
      "services": ["PublicService"],
      "dbEntities": ["PublicData", "CommonStatus"]
    }
  },

  "security": {
    "strictMode": true,
    "enforcedConstraints": [
      {
        "constraint": "No hardcoded secrets in source code",
        "severity": "CRITICAL",
        "status": "⚠️ JWT secret still in appsettings.Development.json",
        "mitigation": "Use dotnet user-secrets (dev) + Azure Key Vault (prod)"
      },
      {
        "constraint": "CORS must not combine wildcard origin with AllowCredentials",
        "severity": "CRITICAL",
        "status": "✅ Fixed — using CorsSettings:AllowedOrigins from config",
        "file": "Program.cs"
      },
      {
        "constraint": "Rate limiting required on auth endpoints",
        "severity": "CRITICAL",
        "status": "❌ NOT IMPLEMENTED",
        "target": "/auth/login: 5/hour, /auth/register: 3/24h"
      },
      {
        "constraint": "HTTPS enforcement in production",
        "severity": "CRITICAL",
        "status": "✅ app.UseHttpsRedirection() in MiddlewareDependencyInversion.cs"
      },
      {
        "constraint": "DateTime must always use DateTime.UtcNow",
        "severity": "HIGH",
        "status": "✅ AuditBase uses DateTime.UtcNow"
      },
      {
        "constraint": "JWT secret minimum 32 characters",
        "severity": "HIGH",
        "file": "AuthHandler/Configuration/JwtSettings.cs"
      },
      {
        "constraint": "All DTOs must have input validation",
        "severity": "HIGH",
        "tool": "FluentValidation or DataAnnotations"
      },
      {
        "constraint": "Soft-delete enforcement via query filters",
        "severity": "MEDIUM",
        "status": "✅ .HasQueryFilter(e => !e.IsDeleted) on ApplicationUser"
      },
      {
        "constraint": "No duplicate service interfaces",
        "severity": "MEDIUM",
        "status": "⚠️ ILicenseService exists in BOTH Interface/Licensing/ AND DbContexts/Licensing/"
      }
    ]
  },

  "fileStructure": {
    "authoritative": true,
    "lastVerified": "2026-04-29",
    "keyPaths": {
      "entryPoint": "Program.cs",
      "diContainer": "DependencyContainer/DependencyInversion.cs",
      "middleware": "Middleware/MiddlewareDependencyInversion.cs",
      "dbContext": "DbContexts/CalciferAppDbContext.cs",
      "seeding": "Infrastructure/DatabaseInitializer.cs",
      "logging": "Helper/LogWriter/LogWriter.cs",
      "apiResponse": "Helper/ApiResponse/ApiResponseDto.cs",
      "mailSettings": "Helper/MailSetting/ (EmailSettings.cs, MailRequest.cs)",
      "authMinimalApis": "AuthHandler/MinimalApis/ (IdentityApi.cs, LicenseApi.cs)",
      "rbacMinimalApi": "Rbac/MinimalApis/RbacMinimalApi.cs",
      "publicApis": "MinimalApis/PublicApis/ (PublicCRUDApis.cs, CommonStatusApi.cs)",
      "filters": "AuthHandler/Filters/ (AuthorizationFilter.cs, RbacFilter.cs, LicenseValidationFilter.cs)",
      "claims": "AuthHandler/Claims/CustomClaims.cs",
      "jwtConfig": "AuthHandler/Configuration/JwtSettings.cs",
      "authModels": "DbContexts/AuthModels/ (ApplicationUser.cs, ApplicationRole.cs)",
      "rbacEntities": "Rbac/Entities/ (OrganizationUnit, Permission, RolePermission, UserUnitRole, UserDirectPermission, PermissionCache)",
      "rbacService": "Rbac/Services/Rbacservice.cs",
      "rbacInterface": "Rbac/Interfaces/IRbacService.cs",
      "rbacDTOs": "Rbac/DTOs/RbacDTOs.cs",
      "rbacEnums": "Rbac/Enums/Rbacenums.cs",
      "rbacExtensions": "Rbac/Extensions/RbacExtensions.cs",
      "rbacSeeds": "Rbac/Seeds/ (OrgUnitSeeder.cs, Rbacpermissionseeder.cs)",
      "licensingModels": "DbContexts/Licensing/ (License.cs, LicenseType.cs, LicenseFeature.cs, LicenseActivation.cs)",
      "commonModels": "DbContexts/Common/ (Auditbase.cs, CommonStatus.cs, TableOperationDetails.cs)",
      "dtos": "DbContexts/DTOs/ (AuthDTO/, CommonDTO/, LicenseDTO/, ModelsDTO/, ClientTypeDto.cs, PublicDataDTO.cs)",
      "services": "Services/ (AuthService/, LicenseService/, PublicService.cs)",
      "interfaces": "Interface/ (Common/IPublicInterface.cs, Licensing/ILicenseService.cs)"
    },
    "legacyControllers": {
      "keep": "Controllers/HomeController.cs (example only)",
      "pendingDeletion": [
        "AuthHandler/AuthController/AuthController.cs",
        "AuthHandler/AuthController/RoleController.cs"
      ],
      "usageExamples": [
        "Controllers/UsageExamples/EmployeeController.cs",
        "Controllers/UsageExamples/IEmployeeService.cs"
      ]
    }
  },

  "dependencyMap": {
    "authService": ["TokenService", "RoleService", "IRbacService", "UserManager<ApplicationUser>"],
    "tokenService": ["JwtSettings", "IRbacService"],
    "rbacService": ["CalciferAppDbContext", "PermissionCache"],
    "licenseService": ["CalciferAppDbContext"],
    "allServices": ["ILogger<T>", "IConfiguration", "CalciferAppDbContext"]
  },

  "databaseStrategy": {
    "orm": "Entity Framework Core 8.0.1",
    "provider": "Microsoft.EntityFrameworkCore.SqlServer",
    "context": "CalciferAppDbContext (inherits IdentityDbContext<ApplicationUser, ApplicationRole, string>)",
    "keyPattern": "Soft-delete with query filters",
    "migrations": "Code-first approach with EF Core migrations",
    "seeding": "DatabaseInitializer.cs (idempotent on startup)"
  },

  "codeStyleGuidelines": {
    "enforced": true,
    "rules": [
      "Use nullable reference types (#nullable enable)",
      "Async/await for all I/O operations (no .Result blocking)",
      "Dependency injection via constructor only (no service locator)",
      "DTOs for all request/response shapes (no domain model leakage)",
      "Layer separation: API → DTO → Service → Interface → Data",
      "Minimal APIs preferred over Controllers for new endpoints",
      "Magic strings prohibited - use constants in CustomClaims.cs",
      "Query filters for soft-deleted entities",
      "Explicit .Include() for eager loading (no N+1 queries)",
      "DateTime.UtcNow ALWAYS (never DateTime.Now)",
      "ILogWriter injected into all services for audit trail",
      "Correlation IDs passed to all logging calls",
      "Try-catch blocks must log via ILogWriter"
    ]
  },

  "developmentCommands": {
    "setup": [
      { "description": "Restore dependencies", "command": "dotnet restore" },
      { "description": "Initialize user secrets", "command": "dotnet user-secrets init" },
      { "description": "Set JWT secret (min 32 chars)", "command": "dotnet user-secrets set \"JwtSettings:Secret\" \"your-super-secret-key-minimum-32-characters-required-here\"" },
      { "description": "Set database connection string", "command": "dotnet user-secrets set \"ConnectionStrings:CalciferDBContext\" \"Server=(localdb)\\\\mssqllocaldb;Database=CalciferDb;Trusted_Connection=True;TrustServerCertificate=True\"" }
    ],
    "database": [
      { "description": "Apply migrations and seed data", "command": "dotnet ef database update" },
      { "description": "Create new migration", "command": "dotnet ef migrations add <MigrationName>" },
      { "description": "Remove last migration", "command": "dotnet ef migrations remove" },
      { "description": "Generate migration script", "command": "dotnet ef migrations script -o migration.sql" }
    ],
    "build": [
      { "description": "Build project", "command": "dotnet build" },
      { "description": "Build release with warnings as errors", "command": "dotnet build -c Release /p:TreatWarningsAsErrors=true" }
    ],
    "run": [
      { "description": "Run with hot-reload", "command": "dotnet watch run" },
      { "description": "Run standard", "command": "dotnet run" },
      { "description": "Run in production configuration", "command": "dotnet run --environment Production" }
    ],
    "testing": [
      { "description": "Run all tests", "command": "dotnet test" },
      { "description": "Run with coverage", "command": "dotnet test /p:CollectCoverage=true /p:CoverageFormat=opencover" },
      { "description": "Test login endpoint", "command": "curl -X POST https://localhost:7007/api/v1/auth/login -H \"Content-Type: application/json\" -d '{\"email\":\"admin@calcifer.local\",\"password\":\"Admin@12345\"}'" },
      { "description": "Test public endpoint", "command": "curl https://localhost:7007/api/v1/public" }
    ],
    "deployment": [
      { "description": "Publish for deployment", "command": "dotnet publish -c Release -o ./publish" },
      { "description": "Create Docker image", "command": "docker build -t calcifer-api:latest -f Dockerfile ." }
    ]
  },

  "testingStrategy": {
    "framework": "xUnit + Moq + FluentAssertions",
    "unitTests": {
      "target": ">80% coverage on AuthService, TokenService, RbacService",
      "patterns": ["Arrange-Act-Assert (AAA)", "Mock IUserManager, ITokenService, ILogWriter", "Test happy path + error scenarios"]
    },
    "integrationTests": {
      "tool": "WebApplicationFactory<Program>",
      "scenarios": [
        "POST /auth/login valid → 200",
        "POST /auth/login invalid → 401",
        "POST /auth/register duplicate → 400",
        "GET /rbac/permissions without permission → 403",
        "Rate limiting on /auth/login after 5 attempts → 429"
      ]
    }
  },

  "implementationRoadmap": {
    "phase1_done": {
      "name": "Logging + Audit Trail",
      "status": "✅ LogWriter implemented, AuditBase has basic fields",
      "pendingWork": [
        "Register ILogWriter in DependencyInversion.cs via services.AddDynamicLogWriter()",
        "Add CorrelationId, IpAddress, UserAgent to AuditBase",
        "Create AuditLog table for field-level change tracking"
      ]
    },
    "phase2_planned": {
      "name": "Token Management (Refresh, Revocation)",
      "status": "❌ Not implemented",
      "work": [
        "Create RefreshToken + TokenRevocation tables (migrations)",
        "Implement POST /api/v1/auth/refresh endpoint",
        "Implement POST /api/v1/auth/logout endpoint",
        "Add token revocation check in RbacFilter"
      ]
    },
    "phase3_planned": {
      "name": "Module System + Dynamic Loading",
      "status": "❌ Not implemented",
      "work": [
        "Create IModule interface",
        "Implement AuthModule (core), RbacModule (optional)",
