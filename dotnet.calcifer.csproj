<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageId>dotnet.calcifer</PackageId>
    <Version>1.0.0</Version>
    <Authors>Rakibul</Authors>
    <Description>Secure .NET 8 API with JWT And Role Management</Description>
    <PackageTags>dotnet-new;webapi;jwt;identity;microservice</PackageTags>
    <TargetFramework>net8.0</TargetFramework>
    <IncludeContentInPack>true</IncludeContentInPack>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoBuild>true</NoBuild>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="src\**\*" Exclude="src\**\bin\**;src\**\obj\**" />

    <Compile Remove="**\*" />
  </ItemGroup>
</Project>