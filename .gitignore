# ═══════════════════════════════════════════════
#  dotnet.calcifer — .gitignore
#  Calcifer Microservice API Template
# ═══════════════════════════════════════════════

# ─────────────────────────────────────────────
# Visual Studio / IDEs
# ─────────────────────────────────────────────
.vs/
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.user
*.userosscache
*.sln.docstates
*.suo
*.vssscc
*.sln.ide/
*.rsuser
*.sln.iml

# ─────────────────────────────────────────────
# Build & Publish Artifacts
# ─────────────────────────────────────────────
[Bb]in/
[Oo]bj/
[Oo]ut/
[Pp]ublish/
[Dd]ebug/
[Rr]elease/
artifacts/
TestResults/
.dotnet/
*.nupkg
*.snupkg
*.ilk
*.exp
*.dll
*.exe
*.pdb

# ─────────────────────────────────────────────
# NuGet
# ─────────────────────────────────────────────
*.nuget.props
*.nuget.targets
packages/
project.lock.json
project.fragment.lock.json
*.packages.lock.json

# ─────────────────────────────────────────────
# .NET / MSBuild
# ─────────────────────────────────────────────
*.cache
*.log
*.mdb
*.pidb
launchSettings.user.json
BundleArtifacts/
MigrationBackup/
StyleCopReport.xml
*.DotSettings.user

# ─────────────────────────────────────────────
# Configuration & Secrets
#   ⚠ Never commit real connection strings,
#     JWT secrets, or API keys.
# ─────────────────────────────────────────────
appsettings.json
appsettings.*.json
!appsettings.Development.json
!appsettings.Example.json
appsettings.user.json
appsettings.Local.json
.env
.env.*
!.env.example
*.pfx
*.publishsettings
secrets.json

# ─────────────────────────────────────────────
# Template-Specific Ignores
#   Generated test projects from `dotnet new`
# ─────────────────────────────────────────────
TestService/
InventoryService/
out/

# ─────────────────────────────────────────────
# OS Generated Files
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────
# Frontend / Node (if applicable)
# ─────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache